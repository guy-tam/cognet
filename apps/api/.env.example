# מסד נתונים
DATABASE_URL=postgresql+asyncpg://cognet:cognet@localhost:5432/cognet_ldi

# Redis
REDIS_URL=redis://localhost:6379/0

# אפליקציה
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# LLM (אופציונלי — המערכת ממשיכה לפעול ללא מפתח זה)
ANTHROPIC_API_KEY=

# Pipeline
DEFAULT_PIPELINE_COUNTRY=IL
DEFAULT_PIPELINE_LANGUAGE=he
MAX_OPPORTUNITIES_PER_RUN=100
MINIMUM_OPPORTUNITY_SCORE=0.35
MINIMUM_CONFIDENCE_SCORE=0.20
